<div style={{padding:16}}> 
<div style={{fontSize:11,color:'#f0a500',fontWeight:700,letterSpacing:'0.1em',marginBottom:16}}>💼 JOB SEARCH — SE TEXAS</div> {[ 
{title:'Operations Coordinator',type:'Full-Time',desc:'20+ years manufacturing ops leadership. Forklift certified. Team supervision. Log reporting. Prefer indoor/office environment.'}, 
{title:'Warehouse Supervisor',type:'Full-Time',desc:'Lead Production Operator background at Lion Elastomers (plant closed Dec 2025). Conveyor systems, robotics, 3-shift operations management.'}, 
{title:'Office/Admin Coordinator',type:'Full-Time',desc:'Strong organizational and reporting skills from manufacturing ops. Computer literate. Professional communication.'}, 
{title:'Plant Operations Manager',type:'Full-Time',desc:'Senior-level manufacturing leadership. Process optimization, team training, safety compliance, production reporting.'}, 
].map((j,i)=>( 
<div key={i} style={{background:'#0d1017',border:'1px solid #1e2433',borderRadius:14,padding:16,marginBottom:12}}> 
<div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:8}}> 
<div style={{fontSize:15,fontWeight:700,color:'#e8eaf0'}}>{j.title}</div> 
<div style={{background:'#1e2433',borderRadius:6,padding:'3px 8px',fontSize:10,color:'#f0a500',fontWeight:700}}>{j.type}</div> 
</div> 
<div style={{fontSize:12,color:'#6b7280',lineHeight:1.6,marginBottom:10}}>{j.desc}</div> 
<button onClick={()=>{setTab('becky');setBeckyInput(`Write a strong cover letter for John Lanter applying for ${j.title} position. John is 59, lives in Orange Texas, 20+ years manufacturing experience as Lead Production Operator at Lion Elastomers (plant closed December 2025). Skills: forklift certified, conveyor systems, robotics, team supervision, log reporting. Looking for indoor/office work. Professional but warm tone.`);}} style={{background:'#141822',border:'1px solid #f0a50044',borderRadius:8,color:'#f0a500',padding:'8px 14px',fontSize:11,fontWeight:700,cursor:'pointer'}}> BECKY WRITES COVER LETTER → </button> 
</div> 
))} <div style={{background:'#0d1017',border:'1px solid #1e2433',borderRadius:14,padding:16,marginTop:8}}> 
<div style={{fontSize:11,color:'#10b981',fontWeight:700,letterSpacing:'0.1em',marginBottom:8}}>JOHN'S STRENGTHS</div> {['20+ years manufacturing operations','Lead Production Operator — Lion Elastomers','Forklift certified','Conveyor systems & robotics','Team supervision & training','Log reporting & documentation','Hub Engine V4 CEO — AI media production','AffiliateMediaHub Studio founder'].map((s,i)=>( 
<div key={i} style={{fontSize:12,color:'#b0b8d0',padding:'4px 0',borderBottom:'1px solid #1e2433',display:'flex',gap:8}}> 
<span style={{color:'#10b981'}}>✓</span>{s} </div> 
))} </div> </div> 
); 
const renderActors=()=>( 
<div style={{padding:16}}> 
<div style={{fontSize:11,color:'#f0a500',fontWeight:700,letterSpacing:'0.1em',marginBottom:16}}>🎭 YOUR STUDIO CAST</div> {[ 
{name:'LISA',role:'Lead News Anchor',schedule:'Friday + Saturday Affiliate',shows:'Podcast (with Susan)',blazer:'Black blazer',style:'CNN-style · Authoritative · Fact-based',emoji:'📰',color:'#3b82f6',tip:'Best for: Tech news, AI developments, serious analysis, credible endorsements'}, 
{name:'SUSAN',role:'Authority Expert',schedule:'Monday Show',shows:'Podcast (with Lisa) · Business (with Alisha)',blazer:'Navy blazer',style:'Warm · Credible · Knowledgeable',emoji:'👩‍💼',color:'#10b981',tip:'Best for: Business content, tutorials, lifestyle, trustworthy recommendations'}, 
{name:'PAUL',role:'Trusted Grandfather',schedule:'Thursday Show',shows:'Podcast 2 (with Alisha)',blazer:'Overalls · Beard',style:'Deep · Steady · Grandfatherly Authority',emoji:'👴',color:'#f59e0b',tip:'Best for: Breaking news, bold claims, trust content, urgent topics'}, 
{name:'ALISHA',role:'Charismatic Host',schedule:'Wednesday Show',shows:'Podcast 2 (with Paul) · Business (with Susan)',blazer:'Blue top · Glasses',style:'Energetic · Persuasive · FOMO-driven',emoji:'⭐',color:'#e879f9',tip:'Best for: Affiliate promos, product launches, sales content, high energy'}, 
{name:'BECKY HOST',role:'Affiliate Show Host',schedule:'As needed',shows:'Affiliate Show (with Becky Guest)',blazer:'Gold blouse',style:'Professional · Interview-style · Engaging',emoji:'🎙',color:'#f0a500',tip:'Best for: Product discovery interviews, affiliate deep dives'}, 
{name:'BECKY GUEST',role:'Expert Guest',schedule:'As needed',shows:'Affiliate Show (with Becky Host)',blazer:'White blouse',style:'Expert · Enthusiastic · Recommender',emoji:'💡',color:'#f0a500',tip:'Best for: Tool reviews, discovery stories, affiliate recommendations'}, 
].map((a,i)=>( 
<div key={i} style={{background:'#0d1017',border:`1px solid ${a.color}33`,borderRadius:14,padding:16,marginBottom:12}}> 
<div style={{display:'flex',alignItems:'center',gap:12,marginBottom:10}}> 
<div style={{width:44,height:44,borderRadius:12,background:a.color+'22',border:`1.5px solid ${a.color}`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:22,flexShrink:0}}> {a.emoji} </div> 
<div style={{flex:1}}> 
<div style={{fontSize:16,fontWeight:800,color:a.color}}>{a.name}</div> 
<div style={{fontSize:11,color:'#6b7280'}}>{a.role} · {a.blazer}</div> 
</div> 
<div style={{background:a.color+'22',borderRadius:6,padding:'3px 8px',fontSize:9,color:a.color,fontWeight:700,textAlign:'right'}}>{a.schedule}</div> </div> 
<div style={{fontSize:11,color:'#6b7280',marginBottom:6}}>Shows: {a.shows}</div> 
<div style={{fontSize:11,color:'#b0b8d0',marginBottom:8,lineHeight:1.5}}>{a.tip}</div> 
<button onClick={()=>{setTab('becky');setBeckyInput(`Write a complete 60-second ${a.name} video script and full Wan2.2 production package for today. Include: script, ElevenLabs voice settings, 8 scene prompts, FFmpeg command, CapCut instructions, and YouTube package.`);}} style={{background:'#141822',border:`1px solid ${a.color}44`,borderRadius:8,color:a.color,padding:'8px 14px',fontSize:11,fontWeight:700,cursor:'pointer',width:'100%'}}> BECKY: BUILD {a.name} VIDEO → </button> 
</div> 
))} </div> 
); 
const renderStudio=()=>{ 
if(lesson)return renderLesson(); 
if(track)return renderTrack(); 
return( 
<div style={{padding:16}}> 
<div style={{fontSize:11,color:'#f0a500',fontWeight:700,letterSpacing:'0.1em',marginBottom:16}}>🎬 STUDIO — COURSES & TRAINING</div> {TRACKS_WITH_PROGRESS.map((t,i)=>{ 
const done=t.lessons.filter(l=>progress[t.id+'_'+l.title]).length; 
const pct=Math.round((done/t.lessons.length)*100); 
return( 
<button key={i} onClick={()=>{setTrack(t);setLesson(null);}} style={{width:'100%',background:'#0d1017',border:`1px solid ${t.color}33`,borderRadius:16,padding:18,marginBottom:12,textAlign:'left',cursor:'pointer'}}> 
<div style={{display:'flex',alignItems:'center',gap:14,marginBottom:10}}> 
<div style={{fontSize:32,flexShrink:0}}>{t.emoji}</div> 
<div style={{flex:1}}> 
<div style={{display:'flex',alignItems:'center',gap:8,marginBottom:4}}> 
<div style={{fontSize:15,fontWeight:800,color:'#e8eaf0'}}>{t.title}</div> {t.badge&&<span style={{background:'#f0a500',color:'#06070d',fontSize:8,fontWeight:800,padding:'2px 5px',borderRadius:4}}>{t.badge}</span>} 
</div> 
<div style={{fontSize:11,color:'#6b7280'}}>{t.lessons.length} lessons · {done} complete</div> 
</div> </div> 
<div style={{background:'#1e2433',borderRadius:4,height:4,overflow:'hidden'}}> 
<div style={{height:'100%',background:t.color,width:pct+'%',borderRadius:4}}/> </div> 
<div style={{fontSize:10,color:t.color,marginTop:6,fontWeight:700}}>{pct}% complete</div> </button> 
); 
})} </div> 
); 
}; 
return( 
<div style={{maxWidth:600,margin:'0 auto',background:'#06070d',minHeight:'100vh',position:'relative'}}> {modal&&( 
<div className="mbg" onClick={()=>setModal(null)}> 
<div className="modal" onClick={e=>e.stopPropagation()}> 
<div style={{fontSize:18,fontWeight:800,color:'#f0a500',marginBottom:12}}>{modal.title}</div> 
<div style={{fontSize:14,color:'#b0b8d0',lineHeight:1.7,whiteSpace:'pre-wrap'}}>{modal.body}</div> 
<button onClick={()=>setModal(null)} style={{marginTop:16,width:'100%',padding:14,background:'linear-gradient(135deg,#f0a500,#c06000)',border:'none',borderRadius:12,color:'#06070d',fontWeight:800,fontSize:14,cursor:'pointer'}}>GOT IT</button> 
</div> </div> 
)} <div style={{paddingBottom:70}}> 
{tab==='home'&&renderHome()} 
{tab==='becky'&&renderBecky()} 
{tab==='jobs'&&renderJobs()} 
{tab==='actors'&&renderActors()} 
{tab==='studio'&&renderStudio()} 
</div> <nav style={{position:'fixed',bottom:0,left:'50%',transform:'translateX(-50%)',width:'100%',maxWidth:600,background:'#0a0c10',borderTop:'1px solid #1e2433',display:'flex',zIndex:100}}> {navItems.map(n=>( 
<button key={n.id} onClick={()=>{setTab(n.id);if(n.id!=='studio'){setTrack(null);setLesson(null);}}} style={{flex:1,display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',gap:3,background:'none',border:'none',padding:'10px 0',cursor:'pointer',borderTop:`2px solid ${tab===n.id?'#f0a500':'transparent'}`}}> 
<span style={{fontSize:18}}>{n.emoji}</span> 
<span style={{fontSize:9,fontWeight:700,color:tab===n.id?'#f0a500':'#3a4156',letterSpacing:'0.05em'}}>{n.label}</span> 
</button> 
))} </nav> </div> 
); 
} ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App)); 
</script> 
