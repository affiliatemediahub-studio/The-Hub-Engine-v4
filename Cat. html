<textarea value={beckyInput} onChange={e=>setBeckyInput(e.target.value)} onKeyDown={e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendBecky();}}} placeholder="Tell Becky what to build — e.g. 'Build a full Vidnoz affiliate video with Lisa for this Friday'" style={{flex:1,background:'#141822',border:'1px solid #1e2433',borderRadius:12,color:'#e8eaf0',padding:'10px 14px',fontSize:13,resize:'none',minHeight:44,maxHeight:100,fontFamily:'DM Sans,sans-serif'}} rows={1}/> 
<button onClick={sendBecky} disabled={beckyLoading||!beckyInput.trim()} style={{width:44,height:44,background:beckyLoading?'#1e2433':'linear-gradient(135deg,#f0a500,#c06000)',border:'none',borderRadius:12,cursor:'pointer',fontSize:18,opacity:beckyLoading?0.5:1,flexShrink:0}}> ↑ </button> 
</div> </div> 
); 
